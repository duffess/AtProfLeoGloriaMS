{
  "info": {
    "name": "GasStation Hub API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Login (Obter Token JWT)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"123456\"\n}"
        },
        "url": {
          "raw": "http://localhost:8083/api/auth/login",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      }
    },
    {
      "name": "2. Abastecimento (Requer Auth)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer COLE_SEU_ACCESS_TOKEN_AQUI",
            "description": "Substitua pela string do accessToken gerado no request 1"
          }
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "customerId",
              "value": "12345",
              "type": "text"
            },
            {
              "key": "amount",
              "value": "200.00",
              "type": "text"
            },
            {
              "key": "literage",
              "value": "40.0",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "http://localhost:8083/api/supplies/checkout",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "api",
            "supplies",
            "checkout"
          ]
        }
      }
    },
    {
      "name": "3. Consultar Pontos",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8083/api/loyalty/12345/points",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "api",
            "loyalty",
            "12345",
            "points"
          ]
        }
      }
    },
    {
      "name": "4. Refresh Token",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"COLE_SEU_REFRESH_TOKEN_AQUI\"\n}"
        },
        "url": {
          "raw": "http://localhost:8083/api/auth/refresh",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "api",
            "auth",
            "refresh"
          ]
        }
      }
    }
  ]
}